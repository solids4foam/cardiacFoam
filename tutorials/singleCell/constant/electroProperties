FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      electroProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
electroModel singleCellElectro;

singleCellElectroCoeffs
{

    // Cell model selection

    ionicModel    AlievPanfilov;
    tissue    myocyte;


    // Time integration settings

    solutionAlgorithm explicit;
    solver          RKF45;
    initialODEStep  1e-5;
    maxSteps        1000000000;
    absTol          1e-6;
    relTol          1e-4;


    // Stimulus protocol
    singleCellStimulus
    {
        stim_start      20;
        stim_duration   1;
        stim_amplitude  0.4;
        stim_period_S1  1000;
        nstim1          3;
        stim_period_S2  0;
        nstim2          0;
    }



    // optional I/O control

    writeAfterTime  0;
    exportedVariables (Vm s);
    debugPrintVariables (Vm);
	
}
