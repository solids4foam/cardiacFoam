     Units: coordinates [m], edgeLength [mm], conductance [S/m]
-->
<VTKFile type="PolyData" version="0.1" byte_order="LittleEndian">
  <PolyData>
    <Piece NumberOfPoints="8" NumberOfVerts="0"
           NumberOfLines="7" NumberOfStrips="0" NumberOfPolys="0">
      <Points>
        <DataArray type="Float64" NumberOfComponents="3" format="ascii">
          9.950000e-03 1.500000e-03 3.400000e-03
          9.950000e-03 1.500000e-03 2.600000e-03
          7.450000e-03 1.500000e-03 1.600000e-03
          1.245000e-02 1.500000e-03 1.600000e-03
          2.450000e-03 1.150000e-03 2.500000e-04
          1.245000e-02 3.500000e-04 6.500000e-04
          7.450000e-03 1.150000e-03 2.500000e-04
          1.745000e-02 3.500000e-04 6.500000e-04
        </DataArray>
      </Points>

      <Lines>
        <DataArray type="Int32" Name="connectivity" format="ascii">
          0 1 1 2 1 3 2 4 2 5 3 6 3 7
        </DataArray>
        <DataArray type="Int32" Name="offsets" format="ascii">
          2 4 6 8 10 12 14
        </DataArray>
      </Lines>

      <PointData Scalars="nodeType">
        <DataArray type="Int32" Name="nodeType" format="ascii">
