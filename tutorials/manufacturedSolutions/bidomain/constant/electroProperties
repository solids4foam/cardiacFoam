FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      electroProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

myocardiumSolver  bidomainSolver;

bidomainSolverCoeffs
{
    conductivityIntracellular [-1 -3 3 0 0 2 0] (0.111453302 0 0 0.121585420 0 0.030396355);
    conductivityExtracellular [-1 -3 3 0 0 2 0] (0.046165469 0 0 0.050362330 0 0.012590582);

    chi  [0 -1 0 0 0 0 0] 3;
    cm   [-1 -4 4 0 0 2 0] 2;

    ionicModel bidomainFDAManufactured;

    outputVariables
    {
        ionic
        {
            export (u1 u2 u3);
            debug (V u1 u2 u3 Iion);
        }
    }

    verificationModel
    {
        type    manufacturedFDABidomainVerifier;
    }

    // Shared manufactured bidomain parameter.
    // For manufactured-consistent conductivities, set:
    // conductivityExtracellular = ((1 - k)/k) * conductivityIntracellular
    manufacturedBidomain
    {
        k 0.7071067811865476;
    }

    dimension    "3D";

    solutionAlgorithm    implicit;
    CFL 0.1;
    solver RKF45;
    initialODEStep 1e-5;
    maxSteps 1000000000;

    phiERefPoint (0.125 0.05 0.05);
    phiEReferenceValue 0.0;

    externalStimulus
    {
        stimulusLocationMin (0 0 5.5e-3);
        stimulusLocationMax (1.5e-3 1.5e-3 7e-3);
        stimulusDuration [0 0 1 0 0 0 0] 0;
        stimulusIntensity [0 -3 0 0 0 1 0] 0;
        stimulusStartTime 0;
    }

}

