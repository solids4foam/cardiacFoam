// ─────────────────────────────────────────────────────────────────────────────
// SECTION 2D — 3D EIKONAL SOLVER COEFFICIENTS
// (activate by setting: myocardiumSolver eikonalSolver;)
//
// Solves a steady nonlinear anisotropic eikonal-diffusion equation to compute
// activation times psi(x) [s]. No ionic model needed — only physical tissue
// parameters and a reference velocity c0. The stimulus box pins psi = 0 at
// the initial activation site.
// ─────────────────────────────────────────────────────────────────────────────

/*
eikonalSolverCoeffs
{
    // Tissue conductivity tensor [S/m]  (falls back to 0/conductivity if present)
    conductivity  [-1 -3 3 0 0 2 0]  (0.1334 0 0 0.01761 0 0.01761);

    // Surface-to-volume ratio  [1/m]
    chi           [0 -1 0 0 0 0 0]   140000;

    // Membrane capacitance  [F/m²]
    cm            [-1 -4 4 0 0 2 0]  0.01;

    // Reference conduction velocity  [m/s]
    // c0 enters the eikonal equation as the wave-speed normalisation.
    c0            [0 1 -1 0 0 0 0]   0.8;

    // Linearisation scheme:
    //   true  → advection-diffusion approach (more stable, recommended)
    //   false → pure diffusion (simpler, may need tighter PIMPLE relaxation)
    eikonalAdvectionDiffusionApproach  true;

    // Stimulus box — cells inside are pinned to psi = 0 (activation origin)
    stimulusLocationMin  (0 0 5.5e-3);
    stimulusLocationMax  (1.5e-3 1.5e-3 7e-3);
}
*/

