FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      electroProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//
// cardiacFoamv2 — electroProperties template
// ============================================
// Single canonical selector key: 'myocardiumSolver'
// Valid types (registered in myocardiumSolver RTST):
//   monodomainSolver    — 3D reaction-diffusion, single potential (Vm)
//   bidomainSolver      — 3D reaction-diffusion, dual potential (Vm + phiE)
//   eikonalSolver 	 - 3D eikonal-diffusion, no potential
//   singleCellSolver    — 0D ODE-only (no mesh, no diffusion)
//
// Settings live in the matching '<type>Coeffs' subdictionary.
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// ─────────────────────────────────────────────────────────────────────────────
// SECTION 1 — SOLVER SELECTION  (choose exactly one; comment out the others)
// ─────────────────────────────────────────────────────────────────────────────
//
// Valid types registered in the 'myocardiumSolver' runtime table:
//   monodomainSolver  — 3D PDE, single potential (Vm), reaction-diffusion
//   bidomainSolver    — 3D PDE, dual potential (Vm + phiE)
//   singleCellSolver  — 0D ODE-only benchmark (no mesh, no diffusion)
//   eikonalSolver     — steady-state activation-time solver (no ionic model)
//                       extends electroModel directly; registered in its table
//
// Setting key: 'myocardiumSolver <type>;'
// Coefficients must live in the matching '<type>Coeffs { ... }' subdict.

myocardiumSolver  monodomainSolver;   // 3-D monodomain
// myocardiumSolver  bidomainSolver;  // 3-D bidomain
// myocardiumSolver  singleCellSolver;// 0-D single-cell ODE benchmark
// myocardiumSolver  eikonalSolver;   // steady activation-time (no ionic)


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 2A — MONODOMAIN COEFFICIENTS
// ─────────────────────────────────────────────────────────────────────────────

monodomainSolverCoeffs
{
    // --- Tissue conductivity tensor (SI: S/m = kg^-1 m^-3 s^3 A^2) ---
    // Isotropic: (sigma 0 0 0 sigma 0 sigma)  Anisotropic: full 6-component Voigt tensor
    conductivity [-1 -3 3 0 0 2 0] (0.1334 0 0 0.01761 0 0.01761);

    // --- Membrane surface-to-volume ratio  [1/m] ---
    chi   [0 -1 0 0 0 0 0]  140000;

    // --- Membrane capacitance  [F/m^2] ---
    cm    [-1 -4 4 0 0 2 0]  0.01;


    // ── Ionic model ─────────────────────────────────────────────────────────
    // Valid types (registered in ionicModel RTST):
    //   AlievPanfilov | BuenoOrovio | TenTusscher | ORd | Mitchell | ...
    ionicModel    BuenoOrovio;
    tissue        epicardialCells;   // epicardialCells | endocardialCells | mCells | myocyte


    // ── ODE time-integration ────────────────────────────────────────────────
    solutionAlgorithm  explicit;     // explicit | implicit
    solver             RKF45;        // RKF45 | euler | RK4
    initialODEStep     1e-6;         // [s] first adaptive step size
    maxSteps           1000000000;   // hard limit on ODE steps per macro-step
    // absTol          1e-6;         // (optional) absolute tolerance for adaptive solvers
    // relTol          1e-4;         // (optional) relative tolerance

    // ── Time-advance scheme (multi-domain coupling) ──────────────────────────
    // Selects the scheme for advancing coupled domains (myocardium, Purkinje, ECG)
    // Valid types:
    //   staggeredElectrophysicsAdvanceScheme
    //       — Weakly coupled explicit staggered scheme (fast, stable for unidirectional)
    //       — Works with explicit/implicit solutionAlgorithm
    //   pimpleStaggeredElectrophysicsAdvanceScheme
    //       — Strongly coupled segregated scheme with PIMPLE iteration (stable bidirectional)
    //       — Requires solutionAlgorithm = implicit and coupling domains present
    electrophysicsAdvanceScheme  staggeredElectrophysicsAdvanceScheme;
    // electrophysicsAdvanceScheme  pimpleStaggeredElectrophysicsAdvanceScheme;


    // ── Output variables ────────────────────────────────────────────────────
    outputVariables
    {
        ionic
        {
            export  (Vm Jsi);    // fields written to disk at outputTime
            debug   (Vm Iion);   // fields printed to terminal
        }
    }

    // ── Optional verification hook ─────────────────────────────────────────
    // Valid type: manufacturedFDAMonodomainVerifier
    // verificationModel
    // {
    //     type  manufacturedFDAMonodomainVerifier;
    // }


    // ── Stimulus (monodomain volume stimulus) ───────────────────────────────
    monodomainStimulus
    {
        stimulusLocationMin  (0 0 5.5e-3);           // corner of stimulus box [m]
        stimulusLocationMax  (1.5e-3 1.5e-3 7e-3);
        stimulusDuration     [0 0 1 0 0 0 0]  2e-3;  // [s]
        stimulusIntensity    [0 -3 0 0 0 1 0] 50000; // [A/m^3]
        stimulusStartTime    0.0;                     // [s]
    }


    // ── Conduction-system (Purkinje) domains  [OPTIONAL] ───────────────────
    // Remove this block entirely if no Purkinje network is present.
    conductionNetworkDomains
    {
        purkinjeNetwork        // arbitrary name; repeated for multiple networks
        {
            // Factory key — selects the conduction domain implementation.
            // Valid type: purkinjeNetworkModel
            conductionSystemDomain  purkinjeNetworkModel;

            // Graph topology: ( nodeA  nodeB  length[m]  conductance[S/m] )
            edges
            (
                ( 0  1  0.003  3.0 )
                ( 1  2  0.005  3.0 )
                ( 1  3  0.005  3.0 )
            );

            // Indices within 'edges' that terminate at PVJ junctions
            pvjNodes    ( 2  3 );

            // 3-D coordinates of each PVJ junction [m]  (parallel-safe)
            pvjLocations
            (
                (0.00245  0.00115  0.00025)
                (0.00745  0.00115  0.00025)
            );

            // Root node stimulus
            rootStimulus
            {
                startTime  0.0;
                duration   0.002;    // [s]
                intensity  1000.0;   // [A/m³] suprathreshold
            }

            // Coefficients for the graph-level conduction solver
            purkinjeNetworkModelCoeffs
            {
                // ── Graph solver selection ───────────────────────────────────
                // Key: 'conductionSystemSolver <type>;'
                // Default (if omitted): monodomain1DSolver
                //
                // Valid types (registered in GraphConductionSystemSolver RTST):
                //   monodomain1DSolver — implicit cable equation + ionic ODE [DEFAULT]
                //   eikonalSolver      — activation-time only, needs c0 [m/s]
                //
                conductionSystemSolver  monodomain1DSolver;   // or: eikonalSolver

                // --- Eikonal solver: only c0 is required ---
                // conduction velocity [m/s] (must be dimensioned)
                // c0  [0 1 -1 0 0 0 0]  0.8; 

                ionicModel      BuenoOrovio;
                tissue          endocardialCells;
                vm1DRest       -0.084;  // resting potential [V]

                solver          RKF45;
                initialODEStep  1e-6;
                maxSteps        1000000000;

                chi     1400.0;   // [1/m]
                cm      1.0e-2;   // [F/m²]

                outputVariables
                {
                    export  (Vm Icoupling);
                    debug   (Vm);
                }
            }
        }
    }


    // ── Domain couplings (e.g. Purkinje→myocardium)  [OPTIONAL] ────────────
    // Remove this block if no cross-domain coupling is needed.
    domainCouplings
    {
        purkinjeToMyocardium   // arbitrary name
        {
            // Factory key — selects the coupling model.
            // Valid type: pvjResistanceCoupler
            electroDomainCoupler  pvjResistanceCoupler;

            rPvj      500.0;   // [Ω·m²]
            pvjRadius  6e-4;    // [m]
            couplingMode bidirectional; // networkToMyocardium | bidirectional
        }
    }
}


// ─────────────────────────────────────────────────────────────────────────────
