FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      electroProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

electroModel monoDomainElectro;

monoDomainElectroCoeffs
{
    conductivity [-1 -3 3 0 0 2 0] (0.1334177215 0 0 0.133417721 0 0.133417721);
    chi   [0 -1 0 0 0 0 0] 140000;
    Cm    [-1 -4 4 0 0 2 0] 0.01;

    ionicModel BuenoOrovio;
    tissue epicardialCells;

    exportedVariables (u v w s Jfi Jion);
    debugPrintVariables (u v w s Jfi Jion);

    solutionAlgorithm implicit;
    CFL 0.1;
    solver RKF45;
    initialODEStep 1e-5;
    maxSteps 1000000000;

    monodomainStimulus
    {
        stimulusLocationMinList ( (0 0 0) (7e-3 0 0) );
        stimulusLocationMaxList ( (1.0e-3 20.0e-3 0.1e-3) (10.0e-3 8.0e-3 0.1e-3) );
        stimulusStartTimeList ( 0.0 0.34 );
        stimulusDuration [0 0 1 0 0 0 0] 3e-3;
        stimulusIntensity [0 -3 0 0 0 1 0] 50000;
    }

    eikonalAdvectionDiffusionApproach yes;
    c0 [0 0 -0.5 0 0 0 0] 40;
}

