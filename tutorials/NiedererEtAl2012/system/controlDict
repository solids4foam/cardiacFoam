FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     cardiacFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime    0.055;

deltaT    1e-06;

maxCo 		0.1;

writeControl    runTime;

writeInterval   5e-3;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable false;



// ************************************************************************* //


functions
{
    smokeCheck
    {
        #include "smokeCheck"
    }

    Niedererpoints
    {
        #include "Niedererpoints"
    }

    Niedererlines
    {
        #include "Niedererlines"
    }
}
