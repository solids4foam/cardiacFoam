FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      electroProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

myocardiumSolver  monodomainSolver;

electroModelCoeffs
{
    conductivity [-1 -3 3 0 0 2 0] (0.111453302 0 0 0.121585420 0 0.030396355);
    chi  [0 -1 0 0 0 0 0] 3;
    cm   [-1 -4 4 0 0 2 0] 2;

    ionicModel tmanufacturedFDA;

    outputVariables
    {
        ionic
        {
            export (u1 u2 u3);
            debug (V u1 u2 u3 Iion);
        }
    }

    solverHookFields
    {
        preProcess (u1 u2 u3);
    }

    dimension    "1D";

    solutionAlgorithm    implicit;
    CFL 0.1;
    solver RKF45;
    initialODEStep 1e-5;
    maxSteps 1000000000;

    monodomainStimulus
    {
        stimulusLocationMin (0 0 5.5e-3);
        stimulusLocationMax (1.5e-3 1.5e-3 7e-3);
        stimulusDuration [0 0 1 0 0 0 0] 0;
        stimulusIntensity [0 -3 0 0 0 1 0] 0;
        stimulusStartTime 0;
    }

    ecgDomains
    {
        ECG
        {
            ecgSolver pseudoECG;

            pseudoECGSolverCoeffs
            {
                manufactured
                {
                    enabled    yes;
                    dimension    "3D";
                    referenceQuadratureOrder    96;
                    checkQuadratureOrders    (6 12 24 48);
                }

                electrodePositions
                {
                    E1    (-0.5 0.5 0.5);
                    E2    (1.5 0.5 0.5);
                    E3    (1.2 0.23 0.61);
                    E4    (1.35 0.74 0.28);
                    E5    (1.55 0.41 0.83);
                }
            }
        }
    }
}

