FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      electroProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

myocardiumSolver  monodomainSolver;

monodomainSolverCoeffs
{
    // --- 1. Core 3D Myocardium Properties ---
    conductivity [-1 -3 3 0 0 2 0] (0.1334 0 0 0.01761 0 0.01761);
    chi          [0 -1 0 0 0 0 0]  140000;
    cm           [-1 -4 4 0 0 2 0] 0.01;
    
    ionicModel   <myocardiumIonicModel>;
    tissue       epicardialCells;

    solutionAlgorithm  explicit;
    solver             RKF45;
    initialODEStep     1e-6;
    maxSteps           1000000000;
    
    electrophysicsAdvanceScheme  staggeredElectrophysicsAdvanceScheme;

    // Agent: Inject dynamic outputs from cellListModels here
    outputVariables 
    { 
        ionic { export (Vm {{<myocardiumIonicModel>_EXPORTS }}); debug (Vm Iion); } 
    }

    monodomainStimulus
    {
        stimulusLocationMin  (0 0 5.5e-3);
        stimulusLocationMax  (1.5e-3 1.5e-3 7e-3);
        stimulusDuration     [0 0 1 0 0 0 0]  2e-3;
        stimulusIntensity    [0 -3 0 0 0 1 0] 50000;
        stimulusStartTime    0.0;
    }

    // --- 2. 1D Purkinje Network Coupling ---
    conductionNetworkDomains
    {
        purkinjeNetwork
        {
            conductionSystemDomain  purkinjeNetworkModel;
            edges ( ( 0  1  0.003  3.0 ) ( 1  2  0.005  3.0 ) ( 1  3  0.005  3.0 ) );
            pvjNodes     ( 2  3 );
            pvjLocations ( (0.00245  0.00115  0.00025) (0.00745  0.00115  0.00025) );

            rootStimulus { startTime 0.0; duration 0.002; intensity 1000.0; }

            purkinjeNetworkModelCoeffs
            {
                conductionSystemSolver  monodomain1DSolver;
                ionicModel      <purkinjeIonicModel>;
                tissue          endocardialCells;
                vm1DRest        -0.084;
                solver          RKF45;
                initialODEStep  1e-6;
                maxSteps        1000000000;
                chi             1400.0;
                cm              1.0e-2;
                outputVariables { export (<purkinjeIonicModel>_SPECIFIC Vm Icoupling); debug (Vm); }
            }
        }
    }

    // --- 3. PVJ Resistance Coupler ---
    domainCouplings
    {
        purkinjeToMyocardium
        {
            electroDomainCoupler  pvjResistanceCoupler;
            rPvj                  500.0;
            pvjRadius             6e-4;
            couplingMode          bidirectional;
        }
    }

    // --- 4. Pseudo-ECG Monitoring ---
    ecgDomains
    {
        bodySurfaceECG
        {
            ecgSolver  pseudoECG;
            electrodePositions
            {
                lead_I   ( 0.1  0.0  0.0 );
                lead_II  ( 0.0  0.1  0.0 );
                lead_V1  ( 0.02 0.02 0.05); // Example chest lead
            }
        }
    }
}
// ************************************************************************* //
