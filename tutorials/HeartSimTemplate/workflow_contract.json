{
  "contract_version": 2,
  "tutorial_family": "HeartSimTemplate",
  "purpose": "Authoring contract for full cardiac electrophysiology cases built from reusable workflow templates and grounded against a runnable HeartPurkinje reference case.",
  "status": {
    "template_kind": "symbolic_authoring_template",
    "runnable_without_substitution": false,
    "future_work": [
      "Replace symbolic ionic-model placeholders with concrete model selections before attempting to run.",
      "Define a formal protocol for Purkinje-specific ionic export variable discovery, analogous to the myocardium export-variable query flow."
    ]
  },
  "reference_workflow_case": {
    "entry_path": "HeartPurkinje_MonopECG/HeartPurkinje",
    "entry_kind": "workflow_case",
    "notes": [
      "This case is the runnable vocabulary reference for the monodomain + Purkinje + pseudo-ECG workflow family.",
      "Reference-only keys present in that case but not promoted into the canonical contract are listed under legacy_reference_keys."
    ],
    "legacy_reference_keys": [
      "purkinjeConductivity"
    ]
  },
  "base_case": {
    "core_required_files": [
      "constant/electroProperties",
      "constant/physicsProperties"
    ],
    "solver_required_files": [
      "system/controlDict",
      "system/fvSchemes",
      "system/fvSolution"
    ],
    "conditional_files": [
      "system/decomposeParDict",
      "system/blockMeshDict",
      "Allrun",
      "Allclean",
      "README.md"
    ],
    "system_baseline_files": [
      "system/fvSchemes",
      "system/fvSolution"
    ]
  },
  "agent_protocols": {
    "ionic_variable_exports": {
      "strategy": "dynamic_query",
      "required": true,
      "description": "Do not hardcode ionic export variables. Query the available variables for the selected ionic model before writing outputVariables.ionic.export.",
      "tool": "listCellModelsVariables",
      "output_target": "monodomainSolverCoeffs.outputVariables.ionic.export",
      "fallback_exports": [
        "Vm"
      ],
      "notes": [
        "Use the selected ionicModel from electroProperties as the lookup input.",
        "Keep debug output conservative, typically (Vm Iion), unless the user explicitly requests more."
      ]
    },
    "purkinje_ionic_variable_exports": {
      "strategy": "future_work",
      "required": false,
      "description": "Purkinje ionic export placeholders are currently symbolic and must be replaced by a future code-backed export-variable discovery path before automatic case authoring can make them runnable.",
      "output_target": "monodomainSolverCoeffs.conductionNetworkDomains.<name>.purkinjeGraphModelCoeffs.outputVariables.export"
    }
  },
  "workflow_templates": [
    {
      "workflow_id": "monodomain_purkinje_pseudo_ecg",
      "title": "3D Monodomain + 1D Purkinje + Pseudo-ECG",
      "myocardiumSolver": "monodomainSolver",
      "electro_scope": "monodomainSolverCoeffs",
      "required_blocks": [
        "monodomainSolverCoeffs",
        "monodomainSolverCoeffs.externalStimulus",
        "monodomainSolverCoeffs.conductionNetworkDomains",
        "monodomainSolverCoeffs.domainCouplings",
        "monodomainSolverCoeffs.ecgDomains"
      ],
      "required_keys": [
        "monodomainSolverCoeffs.ionicModel",
        "monodomainSolverCoeffs.tissue",
        "monodomainSolverCoeffs.solutionAlgorithm",
        "monodomainSolverCoeffs.electrophysicsAdvanceScheme",
        "monodomainSolverCoeffs.conductionNetworkDomains.<name>.conductionSystemDomain",
        "monodomainSolverCoeffs.conductionNetworkDomains.<name>.purkinjeGraphModelCoeffs.conductionSystemSolver",
        "monodomainSolverCoeffs.conductionNetworkDomains.<name>.purkinjeGraphModelCoeffs.graphFile",
        "monodomainSolverCoeffs.conductionNetworkDomains.<name>.purkinjeGraphModelCoeffs.rootStimulus.node",
        "monodomainSolverCoeffs.domainCouplings.<name>.electroDomainCoupler",
        "monodomainSolverCoeffs.ecgDomains.<name>.ecgSolver",
        "monodomainSolverCoeffs.ecgDomains.<name>.electrodePositions.<electrode>"
      ],
      "capabilities": {
        "ecg": true,
        "purkinje": true,
        "verification": false
      },
      "placeholders": {
        "myocardiumIonicModel": "<myocardiumIonicModel>",
        "purkinjeIonicModel": "<purkinjeIonicModel>",
        "purkinjeRootNode": "<purkinjeRootNode>",
        "myocardiumIonicExports": "{{<myocardiumIonicModel>_EXPORTS}}",
        "purkinjeIonicExports": "<purkinjeIonicModel>_SPECIFIC"
      },
      "notes": [
        "This template is symbolic and is intentionally not directly runnable.",
        "The canonical vocabulary for this workflow is grounded against tutorials/HeartPurkinje_MonopECG/HeartPurkinje."
      ]
    },
    {
      "workflow_id": "monodomain_purkinje",
      "title": "3D Monodomain + 1D Purkinje",
      "myocardiumSolver": "monodomainSolver",
      "electro_scope": "monodomainSolverCoeffs",
      "required_blocks": [
        "monodomainSolverCoeffs",
        "monodomainSolverCoeffs.externalStimulus",
        "monodomainSolverCoeffs.conductionNetworkDomains",
        "monodomainSolverCoeffs.domainCouplings"
      ],
      "required_keys": [
        "monodomainSolverCoeffs.ionicModel",
        "monodomainSolverCoeffs.tissue",
        "monodomainSolverCoeffs.solutionAlgorithm",
        "monodomainSolverCoeffs.electrophysicsAdvanceScheme",
        "monodomainSolverCoeffs.conductionNetworkDomains.<name>.conductionSystemDomain",
        "monodomainSolverCoeffs.conductionNetworkDomains.<name>.purkinjeGraphModelCoeffs.conductionSystemSolver",
        "monodomainSolverCoeffs.conductionNetworkDomains.<name>.purkinjeGraphModelCoeffs.graphFile",
        "monodomainSolverCoeffs.domainCouplings.<name>.electroDomainCoupler",
        "monodomainSolverCoeffs.domainCouplings.<name>.conductionNetworkDomain"
      ],
      "capabilities": {
        "ecg": false,
        "purkinje": true,
        "verification": false
      },
      "placeholders": {
        "ionicModel": "{{ IONIC_MODEL_NAME }}",
        "ionicExports": "{{ IONIC_SPECIFIC_EXPORTS }}"
      }
    },
    {
      "workflow_id": "monodomain_pseudo_ecg",
      "title": "3D Monodomain + Pseudo-ECG",
      "myocardiumSolver": "monodomainSolver",
      "electro_scope": "monodomainSolverCoeffs",
      "required_blocks": [
        "monodomainSolverCoeffs",
        "monodomainSolverCoeffs.externalStimulus",
        "monodomainSolverCoeffs.ecgDomains"
      ],
      "required_keys": [
        "monodomainSolverCoeffs.ionicModel",
        "monodomainSolverCoeffs.tissue",
        "monodomainSolverCoeffs.solutionAlgorithm",
        "monodomainSolverCoeffs.electrophysicsAdvanceScheme",
        "monodomainSolverCoeffs.ecgDomains.<name>.ecgSolver",
        "monodomainSolverCoeffs.ecgDomains.<name>.electrodePositions.<electrode>"
      ],
      "capabilities": {
        "ecg": true,
        "purkinje": false,
        "verification": false
      },
      "placeholders": {
        "ionicModel": "{{ IONIC_MODEL_NAME }}",
        "ionicExports": "{{ IONIC_SPECIFIC_EXPORTS }}"
      }
    },
    {
      "workflow_id": "eikonal_purkinje",
      "title": "3D Eikonal + 1D Eikonal",
      "myocardiumSolver": "eikonalSolver",
      "electro_scope": "eikonalSolverCoeffs",
      "required_blocks": [
        "eikonalSolverCoeffs",
        "eikonalSolverCoeffs.conductionNetworkDomains",
        "eikonalSolverCoeffs.domainCouplings"
      ],
      "required_keys": [
        "eikonalSolverCoeffs.c0",
        "eikonalSolverCoeffs.eikonalAdvectionDiffusionApproach",
        "eikonalSolverCoeffs.stimulusLocationMin",
        "eikonalSolverCoeffs.stimulusLocationMax",
        "eikonalSolverCoeffs.conductionNetworkDomains.<name>.conductionSystemDomain",
        "eikonalSolverCoeffs.conductionNetworkDomains.<name>.purkinjeGraphModelCoeffs.conductionSystemSolver",
        "eikonalSolverCoeffs.conductionNetworkDomains.<name>.purkinjeGraphModelCoeffs.graphFile",
        "eikonalSolverCoeffs.conductionNetworkDomains.<name>.purkinjeGraphModelCoeffs.c0",
        "eikonalSolverCoeffs.domainCouplings.<name>.electroDomainCoupler",
        "eikonalSolverCoeffs.domainCouplings.<name>.conductionNetworkDomain",
        "eikonalSolverCoeffs.domainCouplings.<name>.couplingMode"
      ],
      "capabilities": {
        "ecg": false,
        "purkinje": true,
        "verification": false
      },
      "notes": [
        "This workflow is activation-time only and does not require ionic export variables.",
        "Use psi-focused outputVariables in the Purkinje block."
      ]
    }
  ],
  "compatibility_rules": [
    {
      "if": {
        "myocardiumSolver": "monodomainSolver"
      },
      "allows": [
        "externalStimulus",
        "ecgDomains",
        "conductionNetworkDomains",
        "domainCouplings",
        "verificationModel"
      ]
    },
    {
      "if": {
        "myocardiumSolver": "singleCellSolver"
      },
      "allows": [
        "singleCellStimulus",
        "writeAfterTime"
      ],
      "forbids": [
        "externalStimulus",
        "ecgDomains",
        "conductionNetworkDomains",
        "domainCouplings"
      ]
    },
    {
      "if": {
        "myocardiumSolver": "eikonalSolver"
      },
      "allows": [
        "conductionNetworkDomains",
        "domainCouplings"
      ],
      "forbids": [
        "verificationModel"
      ]
    }
  ],
  "provenance": {
    "human_source": "templates.md",
    "schema_source": "applications/scripts/driverFoam/openfoam_driver/dict_entries.py",
    "reference_workflow_case": "tutorials/HeartPurkinje_MonopECG/HeartPurkinje"
  }
}
