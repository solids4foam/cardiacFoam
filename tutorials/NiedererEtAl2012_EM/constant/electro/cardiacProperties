FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant/electro";
    object      cardiacProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Niederer et al 2011 transversely isotropic conductivity [S/m]
conductivity [-1 -3 3 0 0 2 0] (0.1334177215 0 0 0.01760617761 0 0.01760617761);

// Cellular membrane surface-to-volume ratio [1/m]
chi   [0 -1 0 0 0 0 0] 140000;

// Cellular membrane capacitance [F/m^2]
Cm     [-1 -4 4 0 0 2 0] 0.01;

// Specify the ionic model
ionicModel  TNNP;

// Variables to print in terminal (ionic model)
IonicModelVariables_export (Ca_i);
IonicModelVariables_debugPrint (Ca_i);

// Specify the type of tissue
tissue  epicardialCells;

// Eikonal Equation
c0    [0 0 -0.5 0 0 0 0] 40;

// ************************************************************************* //
