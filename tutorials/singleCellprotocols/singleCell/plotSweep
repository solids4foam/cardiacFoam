#!/bin/bash

# Usage:
#   ./plotSweep
#   ./plotSweep Gaur_myocyte_INa_sweep.txt
#   ./plotSweep all AV_INa
#   ./plotSweep --all-vars
#   ./plotSweep --all-vars --exclude AV_tau_h
#   ./plotSweep --all-vars --raw
#   ./plotSweep --dir postProcessing

mode="latest"
var=""
exclude_var=""
plot_all_vars=0
normalize_all_vars=1
data_dir="${PLOT_DIR:-}"
explicit_file=""
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

looks_like_file_arg()
{
    case "$1" in
        *.txt|*.csv|*/*) return 0 ;;
    esac
    [ -f "$1" ]
}

resolve_file()
{
    local candidate="$1"

    if [ -f "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    if [ -n "$data_dir" ] && [ -f "$data_dir/$candidate" ]; then
        printf '%s\n' "$data_dir/$candidate"
        return 0
    fi

    if [ -f "postProcessing/$candidate" ]; then
        printf '%s\n' "postProcessing/$candidate"
        return 0
    fi

    if [ -f "$script_dir/postProcessing/$candidate" ]; then
        printf '%s\n' "$script_dir/postProcessing/$candidate"
        return 0
    fi

    return 1
}

while [ $# -gt 0 ]; do
    case "$1" in
        --dir)
            data_dir="${2:-}"
            shift 2
            ;;
        --exclude)
            exclude_var="${2:-}"
            shift 2
            ;;
        --all-vars)
            plot_all_vars=1
            shift
            ;;
        --raw)
            normalize_all_vars=0
            shift
            ;;
        --normalize)
            normalize_all_vars=1
            shift
            ;;
        all)
            mode="all"
            shift
            if [ $# -gt 0 ] && [ "${1#--}" = "$1" ] && ! looks_like_file_arg "$1"; then
                var="$1"
                shift
            fi
            ;;
        -h|--help)
            echo "Usage:"
            echo "  ./plotSweep [all] [variable]"
            echo "  ./plotSweep <sweep-file>"
            echo "  ./plotSweep --all-vars [--exclude VARIABLE]"
            echo "  ./plotSweep --all-vars [--raw|--normalize]"
            echo "  ./plotSweep --dir <folder> ..."
            exit 0
            ;;
        *)
            if looks_like_file_arg "$1" && [ -z "$explicit_file" ] && [ "$mode" != "all" ]; then
                explicit_file="$1"
            elif [ -z "$var" ]; then
                var="$1"
            else
                echo "Unrecognized argument: $1"
                exit 2
            fi
            shift
            ;;
    esac
done

if [ "$plot_all_vars" = "1" ] && [ "$mode" = "all" ]; then
    echo "--all-vars only supports plotting one file (latest mode)."
    exit 2
fi

if [ "$plot_all_vars" = "1" ] && [ -n "$var" ]; then
    echo "Do not pass a variable name with --all-vars."
    exit 2
fi

if [ -n "$explicit_file" ] && [ "$mode" = "all" ]; then
    echo "Cannot combine explicit file with 'all' mode."
    exit 2
fi

if [ -z "$data_dir" ]; then
    if ls -1 ./*_sweep.txt >/dev/null 2>&1 || ls -1 ./*_sweep.csv >/dev/null 2>&1; then
        data_dir="."
    elif ls -1 postProcessing/*_sweep.txt >/dev/null 2>&1 || ls -1 postProcessing/*_sweep.csv >/dev/null 2>&1; then
        data_dir="postProcessing"
    elif ls -1 "$script_dir"/postProcessing/*_sweep.txt >/dev/null 2>&1 || ls -1 "$script_dir"/postProcessing/*_sweep.csv >/dev/null 2>&1; then
        data_dir="$script_dir/postProcessing"
    else
        data_dir="."
    fi
fi

if [ "${data_dir#/}" = "$data_dir" ] && [ ! -d "$data_dir" ] && [ -d "$script_dir/$data_dir" ]; then
    data_dir="$script_dir/$data_dir"
fi

files=()
if [ -n "$explicit_file" ]; then
    resolved=""
    if ! resolved="$(resolve_file "$explicit_file")"; then
        echo "Sweep file '$explicit_file' was not found."
        exit 1
    fi
    files=("$resolved")
else
    shopt -s nullglob
    candidates=("$data_dir"/*_sweep.txt)
    if [ "${#candidates[@]}" -eq 0 ]; then
        candidates=("$data_dir"/*_sweep.csv)
    fi
    shopt -u nullglob

    sorted=()
    if [ "${#candidates[@]}" -gt 0 ]; then
        while IFS= read -r line; do
            sorted+=("$line")
        done < <(ls -t "${candidates[@]}" 2>/dev/null)
    fi

    if [ "$mode" = "all" ]; then
        files=("${sorted[@]}")
    else
        if [ "${#sorted[@]}" -gt 0 ]; then
            files=("${sorted[0]}")
        fi
    fi
fi

if [ "${#files[@]}" -eq 0 ]; then
    echo "No sweep files (*_sweep.txt or *_sweep.csv) in '$data_dir' (cwd: $(pwd))."
    exit 1
fi

ref="${files[0]}"
field_sep='[[:space:]]*,[[:space:]]*|[[:space:]]+'
header="$(head -n 1 "$ref")"
gnuplot_sep_cmd=""

if echo "$header" | grep -q ","; then
    gnuplot_sep_cmd="set datafile separator ','"
fi

x_name=$(awk -F"$field_sep" 'NR==1 {print $1; exit}' "$ref")
default_y_name=$(awk -F"$field_sep" 'NR==1 {print $2; exit}' "$ref")
[ -z "$x_name" ] && x_name="V"
[ -z "$default_y_name" ] && default_y_name="current"

echo "--------------------------------------------------"
echo "Header of $(basename "$ref"):"
echo "$header"
echo "--------------------------------------------------"
echo "Plotting files:"
printf '%s\n' "${files[@]}"

if [ -n "$var" ] && [ "$mode" != "all" ]; then
    col=$(awk -F"$field_sep" -v v="$var" '
    NR==1{
      for(i=1;i<=NF;i++){
        if($i==v){print i; exit}
      }
      exit
    }' "$ref")

    if [ -z "$col" ]; then
        echo "Variable '$var' not found in header."
        exit 2
    fi
fi

if [ "$plot_all_vars" = "1" ]; then
    ycols=()
    while IFS= read -r line; do
        ycols+=("$line")
    done < <(awk -F"$field_sep" -v ex="$exclude_var" '
        NR==1{
            for(i=2;i<=NF;i++){
                if($i != "" && $i != ex){
                    print i ":" $i
                }
            }
            exit
        }' "$ref")

    if [ "${#ycols[@]}" -eq 0 ]; then
        if [ -n "$exclude_var" ]; then
            echo "No variables left to plot after excluding '$exclude_var'."
        else
            echo "No y-variables found in file."
        fi
        exit 2
    fi

    all_specs=()
    if [ "$normalize_all_vars" = "1" ]; then
        for yc in "${ycols[@]}"; do
            col_i="${yc%%:*}"
            var_i="${yc#*:}"

            stats=$(awk -F"$field_sep" -v c="$col_i" '
                NR==2 {min=$c; max=$c}
                NR>2 {
                    if ($c < min) min=$c;
                    if ($c > max) max=$c;
                }
                END {
                    if (NR < 2) print "0 0";
                    else print min " " max;
                }' "$ref")

            min_i="${stats%% *}"
            max_i="${stats##* }"
            nonzero_range=$(awk -v lo="$min_i" -v hi="$max_i" 'BEGIN {if ((hi-lo) == 0) print 0; else print 1}')

            if [ "$nonzero_range" = "1" ]; then
                all_specs+=("\"$ref\" using 1:((${col_i}-(${min_i}))/((${max_i})-(${min_i}))) with lines title \"${var_i}\"")
            else
                all_specs+=("\"$ref\" using 1:(0.0) with lines title \"${var_i} (const)\"")
            fi
        done

        allPlotCmd="plot $(IFS=', '; echo "${all_specs[*]}")"
        gnuplot -persist <<EOF
set term qt font "DejaVu Sans,10"
${gnuplot_sep_cmd}
set title "Sweep Plot ($(basename "$ref")) - Normalized"
set xlabel "${x_name}"
set ylabel "Normalized value [0,1]"
set yrange [0:1]
set key outside
${allPlotCmd}
EOF
    else
        for yc in "${ycols[@]}"; do
            col_i="${yc%%:*}"
            var_i="${yc#*:}"
            all_specs+=("\"$ref\" using 1:${col_i} with lines title \"${var_i}\"")
        done
        allPlotCmd="plot $(IFS=', '; echo "${all_specs[*]}")"

        gnuplot -persist <<EOF
set term qt font "DejaVu Sans,10"
${gnuplot_sep_cmd}
set title "Sweep Plot ($(basename "$ref"))"
set xlabel "${x_name}"
set ylabel "Variables"
set key outside
${allPlotCmd}
EOF
    fi
    exit 0
fi

ycol=2
if [ "$mode" = "all" ]; then
    y_specs=()
    var_specs=()
    for f in "${files[@]}"; do
        title="$(basename "$f")"
        y_specs+=("\"$f\" using 1:${ycol} with lines title \"$title\"")
        if [ -n "$var" ]; then
            col_f=$(awk -F"$field_sep" -v v="$var" '
            NR==1{
                for(i=1;i<=NF;i++){
                    if($i==v){print i; exit}
                }
                exit
            }' "$f")

            if [ -n "$col_f" ]; then
                var_specs+=("\"$f\" using 1:${col_f} with lines title \"$title\"")
            else
                echo "Skipping '$title' (variable '$var' not found)."
            fi
        fi
    done
    yPlotCmd="plot $(IFS=', '; echo "${y_specs[*]}")"
    if [ -n "$var" ]; then
        if [ "${#var_specs[@]}" -eq 0 ]; then
            echo "Variable '$var' was not found in any selected file."
            exit 2
        fi
        varPlotCmd="plot $(IFS=', '; echo "${var_specs[*]}")"
    fi
else
    yPlotCmd="plot \"${ref}\" using 1:${ycol} with lines title \"${default_y_name}\""
    if [ -n "$var" ]; then
        varPlotCmd="plot \"${ref}\" using 1:${col} with lines title \"${var}\""
    fi
fi

gnuplot -persist <<EOF
set term qt font "DejaVu Sans,10"
${gnuplot_sep_cmd}
set title "Sweep Plot (${default_y_name})"
set xlabel "${x_name}"
set ylabel "${default_y_name}"
set key outside
${yPlotCmd}
EOF

if [ -n "$var" ]; then
    if [ "$mode" = "all" ]; then
        echo "Also plotting '$var' separately across matching files."
    else
        echo "Also plotting '$var' separately (column $col)"
    fi
    gnuplot -persist <<EOF
set term qt font "DejaVu Sans,10"
${gnuplot_sep_cmd}
set title "Sweep Variable (${var})"
set xlabel "${x_name}"
set ylabel "${var}"
set key outside
${varPlotCmd}
EOF
fi
