#!/bin/bash

# Usage:
#   ./plotVoltage
#   ./plotVoltage AV_u
#   ./plotVoltage all AV_u
#   ./plotVoltage --all-vars
#   ./plotVoltage --all-vars --exclude AV_tau_h
#   ./plotVoltage --dir postProcessing
#   PLOT_DIR=postProcessing ./plotVoltage all

mode="latest"
var=""
exclude_var=""
plot_all_vars=0
data_dir="${PLOT_DIR:-}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

while [ $# -gt 0 ]; do
    case "$1" in
        --dir)
            data_dir="${2:-}"
            shift 2
            ;;
        --exclude)
            exclude_var="${2:-}"
            shift 2
            ;;
        --all-vars)
            plot_all_vars=1
            shift
            ;;
        all)
            mode="all"
            shift
            if [ $# -gt 0 ] && [ "${1#--}" = "$1" ]; then
                var="$1"
                shift
            fi
            ;;
        -h|--help)
            echo "Usage:"
            echo "  ./plotVoltage [all] [variable]"
            echo "  ./plotVoltage --all-vars [--exclude VARIABLE]"
            echo "  ./plotVoltage --dir <folder> ..."
            exit 0
            ;;
        *)
            if [ -z "$var" ]; then
                var="$1"
            else
                echo "Unrecognized argument: $1"
                exit 2
            fi
            shift
            ;;
    esac
done

if [ "$plot_all_vars" = "1" ] && [ "$mode" = "all" ]; then
    echo "--all-vars only supports plotting one file (latest mode)."
    exit 2
fi

if [ "$plot_all_vars" = "1" ] && [ -n "$var" ]; then
    echo "Do not pass a variable name with --all-vars."
    exit 2
fi

if [ -z "$data_dir" ]; then
    if ls -1 postProcessing/*.txt >/dev/null 2>&1; then
        data_dir="postProcessing"
    elif ls -1 "$script_dir"/postProcessing/*.txt >/dev/null 2>&1; then
        data_dir="$script_dir/postProcessing"
    else
        data_dir="."
    fi
fi

if [ "${data_dir#/}" = "$data_dir" ] && [ ! -d "$data_dir" ] && [ -d "$script_dir/$data_dir" ]; then
    data_dir="$script_dir/$data_dir"
fi

shopt -s nullglob
candidates=("$data_dir"/*.txt)
if [ "${#candidates[@]}" -eq 0 ]; then
    candidates=("$data_dir"/*.csv)
fi
shopt -u nullglob

sorted=()
if [ "${#candidates[@]}" -gt 0 ]; then
    while IFS= read -r line; do
        sorted+=("$line")
    done < <(ls -t "${candidates[@]}" 2>/dev/null)
fi

files=()
if [ "$mode" = "all" ]; then
    files=("${sorted[@]}")
else
    if [ "${#sorted[@]}" -gt 0 ]; then
        files=("${sorted[0]}")
    fi
fi

if [ "${#files[@]}" -eq 0 ]; then
    echo "No .txt/.csv files found in '$data_dir' (cwd: $(pwd))."
    exit 1
fi

ref="${files[0]}"
field_sep='[[:space:]]*,[[:space:]]*|[[:space:]]+'
header="$(head -n 1 "$ref")"
gnuplot_sep_cmd=""

if echo "$header" | grep -q ","; then
    gnuplot_sep_cmd="set datafile separator ','"
fi

x_name=$(awk -F"$field_sep" 'NR==1 {print $1; exit}' "$ref")
default_y_name=$(awk -F"$field_sep" 'NR==1 {print $2; exit}' "$ref")
[ -z "$x_name" ] && x_name="Time"
[ -z "$default_y_name" ] && default_y_name="Vm"

echo "--------------------------------------------------"
echo "Data directory: $data_dir"
echo "Header of $(basename "$ref"):"
echo "$header"
echo "--------------------------------------------------"

vcol=2

if [ -n "$var" ] && [ "$mode" != "all" ]; then
    col=$(awk -F"$field_sep" -v v="$var" '
    NR==1{
      for(i=1;i<=NF;i++){
        if($i==v){print i; exit}
      }
      exit
    }' "$ref")

    if [ -z "$col" ]; then
        echo "Variable '$var' not found in header."
        exit 2
    fi
fi

echo "Plotting files:"
printf '%s\n' "${files[@]}"

if [ "$plot_all_vars" = "1" ]; then
    ycols=()
    while IFS= read -r line; do
        ycols+=("$line")
    done < <(awk -F"$field_sep" -v ex="$exclude_var" '
        NR==1{
            for(i=2;i<=NF;i++){
                if($i != "" && $i != ex){
                    print i ":" $i
                }
            }
            exit
        }' "$ref")

    if [ "${#ycols[@]}" -eq 0 ]; then
        if [ -n "$exclude_var" ]; then
            echo "No variables left to plot after excluding '$exclude_var'."
        else
            echo "No y-variables found in file."
        fi
        exit 2
    fi

    all_specs=()
    for yc in "${ycols[@]}"; do
        col_i="${yc%%:*}"
        var_i="${yc#*:}"
        all_specs+=("\"$ref\" using 1:${col_i} with lines title \"${var_i}\"")
    done
    allPlotCmd="plot $(IFS=', '; echo "${all_specs[*]}")"

    gnuplot -persist <<EOF
set term qt font "DejaVu Sans,10"
${gnuplot_sep_cmd}
set title "Voltage Plot ($(basename "$ref"))"
set xlabel "${x_name}"
set ylabel "Variables"
set key outside
${allPlotCmd}
EOF
    exit 0
fi

if [ "$mode" = "all" ]; then
    vm_specs=()
    var_specs=()
    for f in "${files[@]}"; do
        title="$(basename "$f")"
        vm_specs+=("\"$f\" using 1:${vcol} with lines title \"$title\"")
        if [ -n "$var" ]; then
            col_f=$(awk -F"$field_sep" -v v="$var" '
            NR==1{
                for(i=1;i<=NF;i++){
                    if($i==v){print i; exit}
                }
                exit
            }' "$f")

            if [ -n "$col_f" ]; then
                var_specs+=("\"$f\" using 1:${col_f} with lines title \"$title\"")
            else
                echo "Skipping '$title' (variable '$var' not found)."
            fi
        fi
    done
    vmPlotCmd="plot $(IFS=', '; echo "${vm_specs[*]}")"
    if [ -n "$var" ]; then
        if [ "${#var_specs[@]}" -eq 0 ]; then
            echo "Variable '$var' was not found in any selected file."
            exit 2
        fi
        varPlotCmd="plot $(IFS=', '; echo "${var_specs[*]}")"
    fi
else
    vmPlotCmd="plot \"${ref}\" using 1:${vcol} with lines title \"${default_y_name}\""
    if [ -n "$var" ]; then
        varPlotCmd="plot \"${ref}\" using 1:${col} with lines title \"${var}\""
    fi
fi

gnuplot -persist <<EOF
set term qt font "DejaVu Sans,10"
${gnuplot_sep_cmd}
set title "Voltage Plot (${default_y_name})"
set xlabel "${x_name}"
set ylabel "${default_y_name}"
set key outside
${vmPlotCmd}
EOF

if [ -n "$var" ]; then
    if [ "$mode" = "all" ]; then
        echo "Also plotting '$var' separately across matching files."
    else
        echo "Also plotting '$var' separately (column $col)"
    fi
    gnuplot -persist <<EOF
set term qt font "DejaVu Sans,10"
${gnuplot_sep_cmd}
set title "Variable Plot (${var})"
set xlabel "${x_name}"
set ylabel "${var}"
set key outside
${varPlotCmd}
EOF
fi
