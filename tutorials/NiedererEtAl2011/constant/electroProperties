FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      electroProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

electroModel monoDomainElectro;
//electroModel eikonalDiffusionElectro;
//electroModel singleCellElectro;

monoDomainElectroCoeffs
{
    solutionAlgorithm explicit;
    //solutionAlgorithm implicit;

    #include "cardiacProperties";
    #include "stimulusProtocol";
    #include "timeIntegrationProperties";

    infoFrequency 1;
}

eikonalDiffusionElectroCoeffs
{
    // eikonal-advection-diffusion approach (yes) or eikonal-diffusion
    // approach (no)
    eikonalAdvectionDiffusionApproach yes;

    #include "cardiacProperties";
    #include "stimulusProtocol";
}

singleCellElectroCoeffs
{
    #include "cardiacProperties";
    #include "stimulusProtocol";
    #include "timeIntegrationProperties"
}

