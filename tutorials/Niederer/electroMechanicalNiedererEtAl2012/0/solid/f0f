FoamFile
{
    version     2.0;
    format      ascii;
    class       surfaceVectorField;
    location    "0/solid";
    object      f0f;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform (1 0 0);

boundaryField
{
    ".*"
    {
        type            calculated;
        value           uniform (1 0 0);
    }
}

