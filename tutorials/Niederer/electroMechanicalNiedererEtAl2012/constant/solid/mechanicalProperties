FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant/solid";
    object      mechanicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

planeStress     no;

mechanical
(
    heartTissue
    {
        type            electroMechanicalLaw;
        rho             rho [1 -3 0 0 0 0 0] 1060;
        activeTension   activeTension [1 -1 -2 0 0 0 0] 0.0;
        rampTime        0.0;
        passiveMechanicalLaw
        {
            type            neoHookeanElastic;
            E               E [1 -1 -2 0 0 0 0] 10e3;
            nu              nu [0 0 0 0 0 0 0] 0.3;
        }
    }
);

