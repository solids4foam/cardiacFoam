FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      electroProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

myocardiumSolver  monodomainSolver;

monodomainSolverCoeffs
{
    conductivity [-1 -3 3 0 0 2 0] (0.1334177215 0 0 0.01760617761 0 0.01760617761);
    chi   [0 -1 0 0 0 0 0] 140000;
    cm    [-1 -4 4 0 0 2 0] 0.01;

    ionicModel    BuenoOrovio;
    tissue    epicardialCells;

    outputVariables
    {
        ionic
        {
            export ( Iion);
            debug (Vm);
        }
    }

    solutionAlgorithm    explicit;
    solver RKF45;
    initialODEStep 1e-6;
    maxSteps 1000000000;
    electrophysicsAdvanceScheme staggeredElectrophysicsAdvanceScheme;



    conductionNetworkDomains
    {
        purkinjeNetwork
        {
            conductionSystemDomain purkinjeGraphModel;

            purkinjeGraphModelCoeffs
            {
                conductionSystemSolver monodomain1DSolver;
                graphFile              purkinjeGraph;

                ionicModel             BuenoOrovio;
                tissue                 epicardialCells;

                chi                    140000;
                cm                     0.01;
                vm1DRest               -0.084;

                rootStimulus
                {
                    node      0;
                    startTime 0.01;
                    duration  0.002;
                    intensity 500000.0;
                }

                solver         RKF45;
                initialODEStep 1e-6;
                maxSteps       1000000000;

                outputVariables
                {
                    export ( Icoupling);
                    debug  ( Icoupling);
                }
            }
        }
    }

    domainCouplings
    {
        couplingA
        {
            electroDomainCoupler    reactionDiffusionPvjCoupler;
            conductionNetworkDomain purkinjeNetwork;
            rPvj                    10000;
            pvjRadius               3e-4;
            couplingMode            unidirectional;
            debugCoupling           true;
        }
    }
}

