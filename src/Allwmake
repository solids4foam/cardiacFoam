
#!/bin/bash
cd ${0%/*} || exit 1    # run from this directory

# Parse arguments for library compilation
if [ -f "$WM_PROJECT_DIR"/wmake/scripts/AllwmakeParseArguments ]
then
    . "$WM_PROJECT_DIR"/wmake/scripts/AllwmakeParseArguments
fi

# Check and define SOLIDS4FOAM_INST_DIR
if [ -z "${_SOLIDS4FOAM_RESOLVED:-}" ]; then
    source "../etc/resolveSolids4Foam.sh"
fi

echo "SOLIDS4FOAM_INST_DIR = $SOLIDS4FOAM_INST_DIR"

# Force Clang to ignore the override warning globally ---
export WM_CXXFLAGS="$WM_CXXFLAGS -Wno-inconsistent-missing-override"


wmake lnInclude couplingModels
wmake $targetType libso genericWriter
wmake $targetType libso ionicModels
wmake $targetType libso verificationModels
wmake $targetType libso activeTensionModels
wmake $targetType libso electroModels

if [ "$USE_LIGHTWEIGHT_PHYSICSMODEL" != "1" ]; then
    wmake $targetType libso electroMechanicalModels
fi

