SOLIDS4FOAM_ROOT := $(SOLIDS4FOAM_INST_DIR)
CARDIACFOAM_LIGHTWEIGHT_ROOT := $(abspath ../../modules/physicsModel)

sinclude $(SOLIDS4FOAM_ROOT)/etc/wmake-options
sinclude $(SOLIDS4FOAM_ROOT)/../etc/wmake-options

ifeq ($(strip $(SOLIDS4FOAM_ROOT)),)
    $(error SOLIDS4FOAM_INST_DIR is not set. Use './Allwmake' or source 'etc/resolveSolids4Foam.sh' before building src/electroModels.)
endif

ifeq ($(strip $(USE_LIGHTWEIGHT_PHYSICSMODEL)),1)
    ifneq ($(abspath $(SOLIDS4FOAM_ROOT)),$(CARDIACFOAM_LIGHTWEIGHT_ROOT))
        $(error USE_LIGHTWEIGHT_PHYSICSMODEL=1 but SOLIDS4FOAM_INST_DIR resolves to '$(abspath $(SOLIDS4FOAM_ROOT))' instead of '$(CARDIACFOAM_LIGHTWEIGHT_ROOT)'. Rebuild through './Allwmake' to keep the physicsModel backend consistent.)
    endif
else
    ifeq ($(abspath $(SOLIDS4FOAM_ROOT)),$(CARDIACFOAM_LIGHTWEIGHT_ROOT))
        $(error SOLIDS4FOAM_INST_DIR points to the bundled lightweight physicsModel root but USE_LIGHTWEIGHT_PHYSICSMODEL is not 1. Rebuild through './Allwmake' to keep the physicsModel backend consistent.)
    endif
endif

ifeq ($(USE_LIGHTWEIGHT_PHYSICSMODEL),1)
    VERSION_SPECIFIC_INC += -DUSE_LIGHTWEIGHT_PHYSICSMODEL
    VERSION_SPECIFIC_LIBS += -lphysicsModel
else
    VERSION_SPECIFIC_LIBS += -lsolids4FoamModels
endif

ifdef PETSC_DIR
    ifneq (,$(findstring -DFOAMEXTEND, $(VERSION_SPECIFIC_INC)))
        include $(RULES)/mplib$(WM_MPLIB)
    else ifneq (,$(findstring -DOPENFOAM_ORG, $(VERSION_SPECIFIC_INC)))
        include $(GENERAL_RULES)/mplibType
    else
        include $(GENERAL_RULES)/mpi-rules
    endif
    VERSION_SPECIFIC_INC += \
        $(PINC) -I$(PETSC_DIR)/include -I$(PETSC_DIR)/$(PETSC_ARCH)/include \
        -DUSE_PETSC
    VERSION_SPECIFIC_LIBS += -L$(PETSC_DIR)/$(PETSC_ARCH)/lib -lpetsc
endif

EXE_INC = \
    $(VERSION_SPECIFIC_INC) \
    -IelectroDomains \
    -IelectroDomains/conductionSystemDomain \
    -IelectroDomains/ecgDomain \
    -IelectroDomains/myocardiumDomain \
    -IconductionSystemModels \
    -ImyocardiumModels \
    -IecgModels \
    -IelectroCouplers \
    -IelectroCouplers/pvjCoupler \
    -IelectroCouplers/pvjCoupler/eikonal \
    -IelectroCouplers/pvjCoupler/reactionDiffusion \
    -Icore \
    -IadvanceSchemes \
    -IadvanceSchemes/staggered \
    -IadvanceSchemes/pimpleStaggered \
    -I../ionicModels/lnInclude \
    -I../verificationModels/lnInclude \
    -I../genericWriter/lnInclude \
    -I../activeTensionModels/lnInclude \
    -I../couplingModels/lnInclude \
    -I../../modules/physicsModel/src/solids4FoamModels/lnInclude \
    -I$(SOLIDS4FOAM_ROOT)/src/solids4FoamModels/lnInclude \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/surfMesh/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/lnInclude \
    -I$(LIB_SRC)/dynamicFvMesh/lnInclude \
    -I$(LIB_SRC)/ODE/lnInclude \

LIB_LIBS = \
    -L$(FOAM_USER_LIBBIN) \
    $(VERSION_SPECIFIC_LIBS) \
    -lverificationModels \
    -lionicModels \
    -lgenericWriter \
    -lactiveTensionModels \
    -lfiniteVolume \
    -lmeshTools \
    -lsurfMesh \
    -ldynamicFvMesh \
    -ldynamicMesh \
    -lODE
